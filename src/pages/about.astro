---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<html lang="en">
	<head>
		<BaseHead title="About - Anatolii Platonov" description="About Anatolii Platonov" />
	</head>
	<body>
		<Header />
		<main>
			<h1>About me</h1>
			<p>
				Hi, I'm Anatolii Platonov — a software engineer passionate about building things
				and understanding how they work under the hood.
			</p>
			<p>
				This blog is a place where I write about programming, share solutions to problems
				I've encountered, and explore ideas in software engineering.
			</p>
			<p>
				You can find me on
				<a href="https://github.com/platonoff-dev">GitHub</a>,
				<a href="https://x.com/platonoff_devv">Twitter/X</a>, and
				<a href="https://linkedin.com/in/platonoff-dev">LinkedIn</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
