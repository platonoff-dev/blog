---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description="All blog posts" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			{posts.length === 0 && <p class="empty">No posts yet. Check back soon.</p>}
			{posts.length > 0 && (
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="title">{post.data.title}</span>
								<span class="meta">
									<span class="description">{post.data.description}</span>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</span>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin: 0 0 1em 0;
	}
	.empty {
		color: var(--text-secondary);
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	li {
		margin: 0;
		border-bottom: 1px solid var(--border);
	}
	li:first-child {
		border-top: 1px solid var(--border);
	}
	a {
		display: flex;
		flex-direction: column;
		padding: 1em 0;
		color: var(--text);
		text-decoration: none;
		gap: 0.25em;
	}
	a:hover {
		text-decoration: none;
	}
	a:hover .title {
		color: var(--accent);
	}
	.title {
		font-weight: 500;
		font-size: 1.05em;
		transition: color 0.15s;
	}
	.meta {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
	}
	.description {
		color: var(--text-secondary);
		font-size: 0.9em;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.date {
		color: var(--text-secondary);
		font-size: 0.85em;
		white-space: nowrap;
	}
</style>
